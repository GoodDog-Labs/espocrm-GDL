{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "maxLength": 255,
            "pattern": "$noBadCharacters"
        },
        "status": {
            "type": "enum",
            "options": [
                "Draft",
                "Sent",
                "Partial",
                "Paid",
                "Overdue",
                "Void",
                "Cancelled"
            ],
            "default": "Draft",
            "displayAsLabel": true,
            "labelType": "state",
            "style": {
                "Draft": "default",
                "Sent": "primary",
                "Partial": "warning",
                "Paid": "success",
                "Overdue": "danger",
                "Void": "default",
                "Cancelled": "default"
            },
            "audited": true
        },
        "account": {
            "type": "link",
            "audited": true
        },
        "contact": {
            "type": "link"
        },
        "quote": {
            "type": "link"
        },
        "subscription": {
            "type": "link"
        },
        "issueDate": {
            "type": "date",
            "required": true
        },
        "dueDate": {
            "type": "date"
        },
        "billingAddress": {
            "type": "address"
        },
        "billingAddressStreet": {
            "type": "text",
            "maxLength": 255,
            "dbType": "varchar"
        },
        "billingAddressCity": {
            "type": "varchar"
        },
        "billingAddressState": {
            "type": "varchar"
        },
        "billingAddressCountry": {
            "type": "varchar"
        },
        "billingAddressPostalCode": {
            "type": "varchar"
        },
        "subtotal": {
            "type": "currency",
            "readOnly": true,
            "min": 0
        },
        "subtotalConverted": {
            "type": "currencyConverted",
            "readOnly": true
        },
        "discountPercent": {
            "type": "float",
            "min": 0,
            "max": 100,
            "decimalPlaces": 2,
            "default": 0
        },
        "discountAmount": {
            "type": "currency",
            "readOnly": true,
            "min": 0
        },
        "discountAmountConverted": {
            "type": "currencyConverted",
            "readOnly": true
        },
        "taxRate": {
            "type": "float",
            "min": 0,
            "max": 100,
            "decimalPlaces": 4,
            "default": 0
        },
        "taxAmount": {
            "type": "currency",
            "readOnly": true,
            "min": 0
        },
        "taxAmountConverted": {
            "type": "currencyConverted",
            "readOnly": true
        },
        "total": {
            "type": "currency",
            "readOnly": true,
            "min": 0,
            "audited": true
        },
        "totalConverted": {
            "type": "currencyConverted",
            "readOnly": true
        },
        "paidAmount": {
            "type": "currency",
            "min": 0,
            "default": 0
        },
        "paidAmountConverted": {
            "type": "currencyConverted",
            "readOnly": true
        },
        "balanceDue": {
            "type": "currency",
            "readOnly": true,
            "min": 0
        },
        "balanceDueConverted": {
            "type": "currencyConverted",
            "readOnly": true
        },
        "stripeInvoiceId": {
            "type": "varchar",
            "maxLength": 255,
            "pattern": "$noBadCharacters"
        },
        "notes": {
            "type": "text"
        },
        "assignedUser": {
            "type": "link",
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true,
            "fieldManagerParamList": ["useNumericFormat"]
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true,
            "fieldManagerParamList": ["useNumericFormat"]
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user",
            "fieldManagerParamList": []
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user",
            "fieldManagerParamList": []
        }
    },
    "links": {
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "invoices",
            "audited": true
        },
        "contact": {
            "type": "belongsTo",
            "entity": "Contact",
            "foreign": "invoices"
        },
        "quote": {
            "type": "belongsTo",
            "entity": "Quote",
            "foreign": "invoices"
        },
        "subscription": {
            "type": "belongsTo",
            "entity": "Subscription",
            "foreign": "invoices"
        },
        "invoiceItems": {
            "type": "hasMany",
            "entity": "InvoiceItem",
            "foreign": "invoice"
        },
        "paymentRequests": {
            "type": "hasMany",
            "entity": "PaymentRequest",
            "foreign": "invoice"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "tasks": {
            "type": "hasChildren",
            "entity": "Task",
            "foreign": "parent",
            "audited": true
        },
        "emails": {
            "type": "hasChildren",
            "entity": "Email",
            "foreign": "parent",
            "layoutRelationshipsDisabled": true
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "issueDate",
        "order": "desc",
        "textFilterFields": ["name", "stripeInvoiceId"]
    },
    "indexes": {
        "status": {
            "columns": ["status", "deleted"]
        },
        "account": {
            "columns": ["accountId", "deleted"]
        },
        "assignedUser": {
            "columns": ["assignedUserId", "deleted"]
        },
        "dueDate": {
            "columns": ["dueDate", "deleted"]
        },
        "createdAt": {
            "columns": ["createdAt", "deleted"]
        },
        "createdAtId": {
            "unique": true,
            "columns": ["createdAt", "id"]
        }
    },
    "optimisticConcurrencyControl": true
}
