{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "maxLength": 150,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "parentCategory": {
            "type": "link"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true,
            "fieldManagerParamList": ["useNumericFormat"]
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true,
            "fieldManagerParamList": ["useNumericFormat"]
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user",
            "fieldManagerParamList": []
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user",
            "fieldManagerParamList": []
        }
    },
    "links": {
        "parentCategory": {
            "type": "belongsTo",
            "entity": "ProductCategory",
            "foreign": "childCategories"
        },
        "childCategories": {
            "type": "hasMany",
            "entity": "ProductCategory",
            "foreign": "parentCategory"
        },
        "products": {
            "type": "hasMany",
            "entity": "Product",
            "foreign": "category"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "name",
        "order": "asc",
        "textFilterFields": ["name"]
    },
    "indexes": {
        "name": {
            "columns": ["name", "deleted"]
        },
        "createdAtId": {
            "unique": true,
            "columns": ["createdAt", "id"]
        }
    }
}
