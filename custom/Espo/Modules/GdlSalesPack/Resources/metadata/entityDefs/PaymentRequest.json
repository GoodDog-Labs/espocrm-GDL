{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "maxLength": 255,
            "pattern": "$noBadCharacters"
        },
        "status": {
            "type": "enum",
            "options": [
                "Pending",
                "Sent",
                "Paid",
                "Expired",
                "Cancelled"
            ],
            "default": "Pending",
            "displayAsLabel": true,
            "labelType": "state",
            "style": {
                "Pending": "default",
                "Sent": "primary",
                "Paid": "success",
                "Expired": "info",
                "Cancelled": "default"
            },
            "audited": true
        },
        "invoice": {
            "type": "link",
            "required": true,
            "audited": true
        },
        "account": {
            "type": "link",
            "audited": true
        },
        "amount": {
            "type": "currency",
            "min": 0,
            "required": true,
            "audited": true
        },
        "amountConverted": {
            "type": "currencyConverted",
            "readOnly": true
        },
        "dueDate": {
            "type": "date"
        },
        "paymentLink": {
            "type": "url"
        },
        "sentAt": {
            "type": "datetime",
            "readOnly": false
        },
        "paidAt": {
            "type": "datetime",
            "readOnly": false
        },
        "notes": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true,
            "fieldManagerParamList": ["useNumericFormat"]
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true,
            "fieldManagerParamList": ["useNumericFormat"]
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user",
            "fieldManagerParamList": []
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user",
            "fieldManagerParamList": []
        }
    },
    "links": {
        "invoice": {
            "type": "belongsTo",
            "entity": "Invoice",
            "foreign": "paymentRequests"
        },
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "paymentRequests"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": ["name", "paymentLink"]
    },
    "indexes": {
        "status": {
            "columns": ["status", "deleted"]
        },
        "invoice": {
            "columns": ["invoiceId", "deleted"]
        },
        "account": {
            "columns": ["accountId", "deleted"]
        },
        "dueDate": {
            "columns": ["dueDate", "deleted"]
        },
        "createdAtId": {
            "unique": true,
            "columns": ["createdAt", "id"]
        }
    }
}
